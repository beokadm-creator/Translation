{
  "name": "server",
  "version": "1.0.0",
  "description": "Realtime relay between admin clients and the OpenAI Realtime API (gpt-realtime-whisper + gpt-4.1-mini).",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "ts-node-dev --respawn --transpile-only --esm src/index.ts",
    "start": "node dist/index.js"
  },
  "keywords": ["realtime", "openai", "gpt-realtime", "whisper", "translation"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.8.0",
    "openai": "^6.34.0",
    "socket.io": "^4.8.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.5.13",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.2"
  }
}
