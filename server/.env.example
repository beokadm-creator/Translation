# Realtime relay environment template — copy to .env and fill in.
# .env is gitignored (see firebase.json:functions.ignore but server/.env is
# not bundled into Functions; ensure your repo .gitignore covers server/.env).

# ── OpenAI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime

# STT: the real upgrade in this branch — streaming gpt-realtime-whisper.
# Roll back to gpt-4o-transcribe by changing this one value.
OPENAI_STT_MODEL=gpt-realtime-whisper

# Translation: gpt-4.1-mini is the default for higher-quality refinement +
# ko/en/ja JSON output. The new model upgrade on the STT side is
# gpt-realtime-whisper.
# OPENAI_TRANSLATION_MODEL=gpt-4.1-mini
# OPENAI_REASONING_MODEL=

# Only applies when OPENAI_REASONING_MODEL points to a reasoning model
# (o-series, gpt-5). Ignored for gpt-4.1-mini / gpt-4o-mini / gpt-4o.
# Values: minimal | low | medium | high | xhigh
# OPENAI_REASONING_EFFORT=medium

# Optional global fallback STT prompts. Prefer project/session personas for
# domain-specific context. Leave empty to avoid hardcoded medical bias.
DEFAULT_STT_PROMPT_KO=
DEFAULT_STT_PROMPT_EN=
DEFAULT_STT_PROMPT_JA=
DEFAULT_STT_PROMPT_ZH=

# ── Firebase Admin ─────────────────────────────────────────────────────
# In Cloud Run, application-default credentials are picked up automatically.
# Locally, set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON path.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_DATABASE_URL=

# ── HTTP / Socket.IO ───────────────────────────────────────────────────
PORT=3000
# Comma-separated origins. "*" allows all (useful only for local dev).
ALLOWED_ORIGINS=http://localhost:5173

# ── Realtime latency tuning ────────────────────────────────────────────
# Admin socket receives every STT delta immediately. This throttles RTDB writes
# for the audience overlay without changing final translation context quality.
REALTIME_PARTIAL_DB_INTERVAL_MS=120

# Quality-first defaults: keep natural speaker pauses inside the same utterance
# so persona/context refinement has enough material before translation.
# Note: gpt-realtime-whisper currently runs through the GA protocol and may
# reject server VAD in some environments; the relay then uses manual commits.
REALTIME_VAD_THRESHOLD=0.5
REALTIME_VAD_PREFIX_PADDING_MS=500
REALTIME_VAD_SILENCE_DURATION_MS=700
REALTIME_MANUAL_COMMIT_INTERVAL_MS=1800

# Realtime STT is instant, but final translation is context-buffered like the
# proven chunked path. Lower these only if latency matters more than context.
REALTIME_TRANSLATION_MIN_CHARS=45
REALTIME_TRANSLATION_TIMEOUT_MS=1800
REALTIME_TRANSLATION_SENTENCE_END=true
