{
  "rules": {
    "conferences": {
      ".read": true,
      ".write": "auth != null"
    },
    "projects": {
      ".read": true,
      "$projectId": {
        ".read": true,
        ".write": "auth != null",
        "stream": {
          ".read": true,
          ".write": "auth != null",
          ".indexOn": [
            "timestamp",
            "status",
            "sessionId"
          ]
        },
        "settings": {
          ".read": true,
          ".write": "auth != null"
        },
        "sessions": {
          "$sessionId": {
            ".read": "auth != null",
            ".write": "auth != null"
          },
          ".read": "auth != null",
          ".write": "auth != null",
          ".indexOn": [
            "accessCode"
          ]
        },
        "activeSessionId": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "state": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}