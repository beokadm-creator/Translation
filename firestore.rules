rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Projects collection
    match /projects/{projectId} {
      allow read: if true; // Public read for dashboard list (or restrict to auth)
      allow write: if request.auth != null; // Only admins can create/edit
    }
    
    // Transcripts subcollection
    match /transcripts/{projectId}/segments/{segmentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Allow users to read their own data (if needed later)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
